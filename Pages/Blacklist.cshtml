@page
@using LineBotLogger.Pages
@model LineBotLogger.Pages.BlacklistModel
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>工作台 - 黑名單</title>
    <link rel="stylesheet" href="/site.css" />
    <style>
        .card { padding: 16px 20px; margin-bottom: 12px; display: flex; align-items: center; gap: 12px; }
        .card .name { font-weight: 600; }
        .card .meta { font-size: 13px; color: var(--label-2); }
        .card form { margin: 0 0 0 auto; }
    </style>
</head>
<body>
    <div class="nav">
        <span class="brand">工作台</span>
        <a asp-page="/Inbox">待審核</a>
        <a class="active" asp-page="/Blacklist">黑名單</a>
        <a asp-page="/KnowledgeBase">知識庫</a>
        <div class="right">
            <a asp-page="/Index">← 工作台</a>
            <span>@User.Identity?.Name</span>
            <form method="post" asp-page="/Logout"><button type="submit">登出</button></form>
        </div>
    </div>

    <div class="wrap">
        @if (Model.Items.Count == 0)
        {
            <p class="empty">黑名單是空的</p>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <div class="card">
                    <span class="name">
                        @(string.IsNullOrWhiteSpace(item.DisplayName)
                            ? InboxModel.ShortId(item.ConversationId)
                            : item.DisplayName)
                    </span>
                    <span class="meta">封鎖於 @InboxModel.ToTaipei(item.CreatedAt)</span>
                    <form method="post" asp-page-handler="Remove">
                        <input type="hidden" name="conversationId" value="@item.ConversationId" />
                        <button type="submit" class="b-gray">解除</button>
                    </form>
                </div>
            }
        }
    </div>
</body>
</html>
