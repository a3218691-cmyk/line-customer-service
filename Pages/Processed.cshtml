@page
@using LineBotLogger.Pages
@model LineBotLogger.Pages.ProcessedModel
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>工作台 - 已處理</title>
    <link rel="stylesheet" href="/site.css" />
    <style>
        .card-head { display: flex; align-items: center; gap: 8px; }
        .cust { font-weight: 600; font-size: 17px; }
        .count { margin-left: auto; font-size: 13px; color: var(--label-2); }
        .sub { font-size: 13px; color: var(--label-2); margin: 16px 0 8px; }
        .thread { max-height: 400px; overflow-y: auto; }
        .row { display: flex; flex-direction: column; margin-bottom: 10px; }
        .row.them { align-items: flex-start; }
        .row.me { align-items: flex-end; }
        .bubble { max-width: 78%; padding: 10px 14px; border-radius: 18px; font-size: 15px; line-height: 1.5; white-space: pre-wrap; word-break: break-word; }
        .them .bubble { background: var(--surface-2); color: var(--label); }
        .me .bubble { background: var(--accent); color: var(--accent-ink); }
        .time { font-size: 11px; color: var(--label-3); margin-top: 3px; }
        .skipped { text-align: center; color: var(--label-3); font-size: 12px; margin: 8px 0; }
    </style>
</head>
<body>
    <div class="nav">
        <a href="/" class="brand">工作台</a>
        <a asp-page="/Inbox">待審核</a>
        <a asp-page="/Supervisor">主管處理區</a>
        <a class="active" asp-page="/Processed">已處理</a>
        <a asp-page="/Blacklist">黑名單</a>
        <a asp-page="/KnowledgeBase">知識庫</a>
        <div class="right">
            <a asp-page="/Index">← 工作台</a>
            <span>@User.Identity?.Name</span>
            <form method="post" asp-page="/Logout"><button type="submit">登出</button></form>
        </div>
    </div>

    <div class="wrap">
        @if (Model.Cards.Count == 0)
        {
            <p class="empty">目前沒有已處理的客人</p>
        }
        else
        {
            @foreach (var card in Model.Cards)
            {
                <div class="card">
                    <div class="card-head">
                        <span class="cust">@card.DisplayName</span>
                        <span class="count">@card.History.Count 則往來</span>
                    </div>

                    <div class="thread">
                        @for (var i = 0; i < card.History.Count; i++)
                        {
                            var entry = card.History[i];
                            if (entry.Role == "user" && entry.Status == "skipped")
                            {
                                var n = 1;
                                while (i + n < card.History.Count
                                       && card.History[i + n].Role == "user"
                                       && card.History[i + n].Status == "skipped")
                                {
                                    n++;
                                }
                                i += n - 1;
                                <div class="skipped">@(n == 1 ? "(已略過)" : $"(已略過 {n} 則)")</div>
                            }
                            else if (entry.Role == "user")
                            {
                                <div class="row them">
                                    <div class="bubble">@InboxModel.BubbleText(entry)</div>
                                    <div class="time">@InboxModel.ToTaipeiShort(entry.DisplayTs)</div>
                                </div>
                            }
                            else
                            {
                                <div class="row me">
                                    <div class="bubble">@InboxModel.BubbleText(entry)</div>
                                    <div class="time">客服回覆 · @InboxModel.ToTaipeiShort(entry.DisplayTs)</div>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        }
    </div>
</body>
</html>
