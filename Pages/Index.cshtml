@page
@model LineBotLogger.Pages.IndexModel
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>工作台</title>
    <link rel="stylesheet" href="/site.css" />
    <style>
        .wrap { padding-top: 32px; }
        .tiles { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
        .tile { display: block; background: var(--surface); border-radius: 16px; padding: 24px; text-decoration: none; color: var(--label); transition: transform 120ms ease-out, filter 120ms ease-out; }
        @@media (hover: hover) and (pointer: fine) { .tile:hover { filter: brightness(1.15); } }
        .tile .name { font-weight: 600; font-size: 17px; }
        .tile .desc { margin-top: 6px; font-size: 13px; color: var(--label-2); }
        .tile .badge { display: inline-block; margin-top: 16px; background: var(--accent); color: var(--accent-ink); border-radius: 999px; padding: 3px 10px; font-size: 13px; font-weight: 700; }
    </style>
</head>
<body>
    <div class="nav">
        <span class="brand">工作台</span>
        <div class="right">
            <span>@User.Identity?.Name</span>
            <form method="post" asp-page="/Logout"><button type="submit">登出</button></form>
        </div>
    </div>

    <div class="wrap">
        <h1 class="page-title">工作台</h1>
        <div class="tiles">
            <a class="tile" asp-page="/Inbox">
                <div class="name">LINE 客服</div>
                <div class="desc">待審核訊息與回覆</div>
                @if (Model.PendingConversations > 0)
                {
                    <div class="badge">@Model.PendingConversations 位待回</div>
                }
            </a>
            <a class="tile" href="/review">
                <div class="name">審片小幫手</div>
                <div class="desc">影片審片、畫記、匯出改片意見</div>
            </a>
        </div>
    </div>
</body>
</html>
